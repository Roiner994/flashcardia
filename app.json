{
  "expo": {
    "name": "Flashcardia",
    "slug": "flashcardia",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "flashcardia",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.roiner.flashcardia",
      "infoPlist": {
        "NSSpeechRecognitionUsageDescription": "Allow $(PRODUCT_NAME) to use speech recognition.",
        "NSMicrophoneUsageDescription": "Allow $(PRODUCT_NAME) to use the microphone."
      }
    },
    "android": {
      "package": "com.roiner.flashcardia",
      "adaptiveIcon": {
        "backgroundColor": "#290F58",
        "foregroundImage": "./assets/images/android-icon-foreground-padded.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "permissions": ["android.permission.RECORD_AUDIO"],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-speech-recognition",
      "@react-native-google-signin/google-signin",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/only-icon.png",
          "resizeMode": "contain",
          "backgroundColor": "#290F58",
          "dark": {
            "backgroundColor": "#290F58"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "8687758c-68bd-4841-8a0f-6b14f03c4df1"
      }
    },
    "owner": "flashcardia"
  }
}
